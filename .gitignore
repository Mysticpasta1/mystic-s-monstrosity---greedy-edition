logs/
*.log
crash-reports/

# Runtime generated
.fabric/
.mixin.out/

# Local player data
saves/

# Shader cache
shaderpacks/.cache/

# Resource pack cache  
resourcepacks/.cache/

# User-specific options
options.txt
optionsof.txt
optionsshaders.txt
servers.dat

# OS generated
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
*.iml
.vscode/

# Backups
*.backup
*.bak

